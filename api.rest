@guestId = {{createGuest.response.body.id}}

### Get Guest by ID
GET {{baseUrl}}/guests/{{guestId}}

################################################################################
# ROOMS
################################################################################

### Create Room
# @name createRoom
POST {{baseUrl}}/rooms
Content-Type: application/json

{
  "number": 102,
  "capacity": 6,
  "pricePerNight": 350.00,
  "status": "available"
}

################################################################################
# RESERVATIONS
################################################################################

### Create Reservation (uses IDs from above)
# @name createReservation
POST {{baseUrl}}/reservations
Content-Type: application/json

{
  "guestId": "{{createGuest.response.body.id}}",
  "roomId": "{{createRoom.response.body.id}}",
  "checkInDate": "2026-08-02",
  "checkOutDate": "2026-08-10"
}

### Cancel Reservation (uses ID from above)
PUT {{baseUrl}}/reservations/{{createReservation.response.body.id}}/cancel
Content-Type: application/json

{
  "reason": "Change of plans",
  "cancelledBy": "guest"
}